# Paths that can't be covered by per-package .sqlfluffignore
# files because they sit outside packages/.  Individual packages
# ignore their own work dirs (e.g. packages/rbtr-eval/data/).

.venv/
node_modules/

# Tool caches — none of these ship SQL today, but ignoring them
# here costs nothing and guards against future false positives.
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Build artefacts.
dist/
build/

# Language sample fixtures are illustrative, not product SQL — validated
# by their own parse-clean/snapshot tests, not by sqlfluff.
packages/rbtr/src/rbtr/tests/languages/samples/

# Language-plugin sample fixtures (illustrative corpora, not product SQL),
# glob-matched so future rbtr-lang-* packages are covered automatically.
packages/rbtr-lang-*/src/*/tests/samples/
