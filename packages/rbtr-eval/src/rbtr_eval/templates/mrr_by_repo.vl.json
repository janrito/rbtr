{
  "$schema": "https://vega.github.io/schema/vega-lite/v6.json",
  "description": "MRR by repository",
  "title": "MRR by repo",
  "width": 400,
  "height": 250,
  "data": {"values": []},
  "mark": {"type": "bar"},
  "encoding": {
    "x": {
      "field": "slug",
      "type": "nominal",
      "title": "Repo",
      "sort": "-y"
    },
    "y": {
      "field": "mrr",
      "type": "quantitative",
      "title": "MRR",
      "scale": {"domain": [0, 1]}
    },
    "tooltip": [
      {"field": "slug", "type": "nominal"},
      {"field": "mrr", "type": "quantitative", "format": ".3f"}
    ]
  }
}
